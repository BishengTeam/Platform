/* ===== 容器 ===== */
.cv-container {
  width: 100%;
  background-color: #0a0e27;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ===== 视频区域 ===== */
.cv-video-wrapper {
  position: relative;
  width: 100%;
}

.cv-video {
  width: 100%;
  height: 420rpx;
}

/* ===== 弹幕遮罩层 ===== */
.cv-danmu-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 10;
}

.cv-danmu-item {
  position: absolute;
  left: 100%;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 500;
  text-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.7);
  pointer-events: none;
}

/* ===== 弹幕发送栏 ===== */
.cv-danmu-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #12163a;
  gap: 16rpx;
}

.cv-danmu-input {
  flex: 1;
  height: 68rpx;
  padding: 0 24rpx;
  background-color: rgba(255, 255, 255, 0.08);
  border-radius: 34rpx;
  color: #e8e8ff;
  font-size: 26rpx;
}

.cv-danmu-placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.cv-danmu-btn {
  width: 128rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  border-radius: 34rpx;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0;
  margin: 0;
  border: none;
}

/* 去除 button 默认边框 */
.cv-danmu-btn::after {
  border: none;
}
